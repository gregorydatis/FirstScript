MachineAcafe

#!/bin/bash


# Fichiers stockage 

stock_café=$(cat stock_café.txt)
stock_thé=$(cat stock_thé.txt)
stock_chocolat=$(cat stock_chocolat.txt)
stock_gobelet=$(cat stock_gobelet.txt)
stock_touillette=$(cat stock_touillette.txt)

echo ""



# Menu des boissons

echo "Choisissez une boisson :"
echo "1) café"
echo "2) thé"
echo "3) chocolat"

echo "Entrez votre choix 1,2 ou 3"
read choix 

if [ "$choix" = "1" ]
then echo "Vous avez choisi café. Bonne dégustation !"
boisson="café"

elif ["$choix" = "2" ]
then echo "Vous avez choisi thé. Bonne dégustation !"
boisson="thé"

elif ["$choix" = "3" ]
then echo "Vous avez choisi chocolat. Bonne dégustation !"
boisson="chocolat"
else    echo "Réponse invalide"
fi

# Gestion des gobelets

read -p "Avez vous un gobelet (Oui/Non) :" gobelet
if [ "$gobelet" = "Oui" ]
then messageGobelet="Vous avez un gobelet"
elif [ "$gobelet" = "Non" ]
then messageGobelet="Vous n'avez pas de gobelet"

else echo "Réponse invalide, veuillez répondre Oui ou Non"
fi

# Gestion du sucre 

read -p "Avez vous du sucre (Oui/Non) : " sucre
if [ "$sucre" = "Oui" ]
then messageSucre="Avec sucre"

elif [ "$sucre" = "Non" ]
then messageSucre="Sans sucre"

else echo "Réponse invalide, veuillez choisir Oui ou Non"
exit 1
fi

# Fichier en fin de script 

echo $stock_café > stock_café.txt
echo $stock_the > stock_thé.txt
echo $stock_chocolat > stock_chocolat.txt
echo $stock_gobelet > stock_gobelet.txt
echo $stock_sucre > stock_sucre.txt
echo $stock_touillette > stock_touillette.txt

# Résumé

echo ""

echo " Récapitulatif "
echo "Boisson    : $boisson"
echo "Gobelet    : $messageGobelet"
echo "Sucre      : $messageSucre"
echo "Touillette : $messageTouillette"
echo ""
echo " Stocks restants "
echo "Café        : $stock_café"
echo "Thé         : $stock_thé"
echo "Chocolat    : $stock_chocolat"
echo "Gobelets    : $stock_gobelet"
echo "Sucre       : $stock_sucre"
echo "Touillettes : $stock_touillette"
